# WHOOP API (get from https://developer-dashboard.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/whoop/callback

# Turso (optional, for cloud DB)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Remote MCP server mode (set to "http" for cloud deployment)
MCP_TRANSPORT=stdio
PORT=8000
